<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <title>{{ subject_line }}</title>
  <style>
    body { margin: 0; padding: 0; background-color: #e8eaf0; }
    img { border: 0; display: block; }
    a { color: #4361ee; text-decoration: none; }
    a:hover { text-decoration: underline; }
    @media only screen and (max-width: 620px) {
      .wrapper { width: 100% !important; }
      .pad { padding: 24px 20px !important; }
      .stat-number { font-size: 42px !important; }
    }
  </style>
</head>
<body>
  <!--[if mso]><div style="font-family:Arial,sans-serif;"><![endif]-->

  <!-- Outer wrapper -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#e8eaf0; padding:32px 16px;">
    <tr>
      <td align="center">
        <div class="wrapper" style="max-width:600px; width:100%;">

          <!-- ═══════════ HEADER ═══════════ -->
          <table width="100%" cellpadding="0" cellspacing="0" border="0"
                 style="background:#0f0e17; border-radius:12px 12px 0 0; overflow:hidden;">
            <tr>
              <td style="padding:12px 32px; border-bottom:1px solid #1e1d2e;">
                <table width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="font-family:system-ui,-apple-system,sans-serif;
                                font-size:13px; font-weight:700; letter-spacing:2px;
                                text-transform:uppercase; color:#4361ee;">
                      {{ newsletter_name }}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td class="pad" style="padding:40px 32px 36px;">
                <p style="font-family:system-ui,-apple-system,sans-serif;
                           font-size:11px; font-weight:600; letter-spacing:3px;
                           text-transform:uppercase; color:#7209b7; margin:0 0 18px;">
                  Intelligence Brief
                </p>
                <h1 style="font-family:system-ui,-apple-system,sans-serif;
                            font-size:30px; font-weight:800; line-height:1.25;
                            color:#ffffff; margin:0 0 20px;">
                  {{ headline }}
                </h1>
                <p style="font-family:system-ui,-apple-system,sans-serif;
                           font-size:16px; line-height:1.7; color:#a0a0c0; margin:0;">
                  {{ intro }}
                </p>
              </td>
            </tr>
          </table>

          <!-- ═══════════ KEY STAT ═══════════ -->
          <table width="100%" cellpadding="0" cellspacing="0" border="0"
                 style="background:#f0f4ff; border-left:4px solid #4361ee;">
            <tr>
              <td class="pad" style="padding:28px 32px;">
                <p class="stat-number"
                   style="font-family:system-ui,-apple-system,sans-serif;
                          font-size:52px; font-weight:900; color:#4361ee;
                          line-height:1; margin:0 0 6px;">
                  {{ key_stat.number }}
                </p>
                <p style="font-family:system-ui,-apple-system,sans-serif;
                           font-size:17px; font-weight:700; color:#0f0e17;
                           margin:0 0 8px;">
                  {{ key_stat.label }}
                </p>
                <p style="font-family:system-ui,-apple-system,sans-serif;
                           font-size:14px; color:#64748b; margin:0; line-height:1.6;">
                  {{ key_stat.context }}
                </p>
              </td>
            </tr>
          </table>

          <!-- ═══════════ CONTENT SECTIONS ═══════════ -->
          <table width="100%" cellpadding="0" cellspacing="0" border="0"
                 style="background:#ffffff;">
            {% for section in sections %}
            <tr>
              <td class="pad"
                  style="padding:36px 32px {% if not loop.last %}0{% else %}36px{% endif %} 32px;">

                <!-- Section number pill -->
                <table cellpadding="0" cellspacing="0" border="0" style="margin-bottom:14px;">
                  <tr>
                    <td style="background:#f0f4ff; border-radius:20px; padding:4px 12px;
                                font-family:system-ui,-apple-system,sans-serif;
                                font-size:11px; font-weight:700; color:#4361ee;
                                letter-spacing:1px; text-transform:uppercase;">
                      0{{ loop.index }}
                    </td>
                  </tr>
                </table>

                <!-- Headline -->
                <h2 style="font-family:system-ui,-apple-system,sans-serif;
                            font-size:21px; font-weight:800; color:#0f0e17;
                            line-height:1.3; margin:0 0 16px;">
                  {{ section.headline }}
                </h2>

                <!-- Body paragraphs -->
                {% for para in section.body.split('\n\n') %}
                <p style="font-family:system-ui,-apple-system,sans-serif;
                           font-size:15px; color:#374151; line-height:1.8;
                           margin:0 0 14px;">
                  {{ para }}
                </p>
                {% endfor %}

                <!-- Infographic -->
                {% if section.infographic_uri %}
                <table width="100%" cellpadding="0" cellspacing="0" border="0"
                       style="margin-top:20px; background:#f8faff;
                              border-radius:8px; overflow:hidden;
                              border:1px solid #e2e8f0;">
                  <tr>
                    <td style="padding:4px;">
                      <img src="{{ section.infographic_uri }}"
                           alt="{{ section.headline }}"
                           width="560"
                           style="width:100%; border-radius:6px;">
                    </td>
                  </tr>
                </table>
                {% endif %}

                <!-- Divider (between sections) -->
                {% if not loop.last %}
                <table width="100%" cellpadding="0" cellspacing="0" border="0"
                       style="margin-top:36px;">
                  <tr>
                    <td style="border-top:1px solid #f1f5f9; font-size:0;">&nbsp;</td>
                  </tr>
                </table>
                {% endif %}

              </td>
            </tr>
            {% endfor %}
          </table>

          <!-- ═══════════ OUTRO / CTA ═══════════ -->
          <table width="100%" cellpadding="0" cellspacing="0" border="0"
                 style="background:linear-gradient(135deg,#0f0e17 0%,#1a1040 100%);">
            <tr>
              <td class="pad" style="padding:36px 32px; text-align:center;">
                <p style="font-family:system-ui,-apple-system,sans-serif;
                           font-size:16px; color:#a0a0c0; line-height:1.7;
                           margin:0 0 24px;">
                  {{ outro }}
                </p>
                {% if sources %}
                <p style="font-family:system-ui,-apple-system,sans-serif;
                           font-size:12px; color:#4a4a6a; margin:0;">
                  Sources:
                  {% for url in sources %}
                  <a href="{{ url }}" style="color:#4361ee;">[{{ loop.index }}]</a>{% if not loop.last %} {% endif %}
                  {% endfor %}
                </p>
                {% endif %}
              </td>
            </tr>
          </table>

          <!-- ═══════════ FOOTER ═══════════ -->
          <table width="100%" cellpadding="0" cellspacing="0" border="0"
                 style="background:#f8f9fc; border-radius:0 0 12px 12px;
                        border-top:1px solid #e2e8f0;">
            <tr>
              <td style="padding:20px 32px; text-align:center;">
                <p style="font-family:system-ui,-apple-system,sans-serif;
                           font-size:12px; color:#94a3b8; margin:0; line-height:1.6;">
                  You're receiving this because you subscribed to <strong>{{ newsletter_name }}</strong>.<br>
                  <a href="#" style="color:#94a3b8;">Unsubscribe</a> &middot;
                  Generated by AI Newsletter Bot
                </p>
              </td>
            </tr>
          </table>

        </div><!-- /wrapper -->
      </td>
    </tr>
  </table>
  <!--[if mso]></div><![endif]-->
</body>
</html>
